{
  "name": "Google-Chat-Takeout-Explorer-DevContainer",
  "image": "mcr.microsoft.com/devcontainers/go:2-1.26-trixie",
  "forwardPorts": [1110],
  "postCreateCommand": "curl -fsSL https://vite.plus | bash",
  "customizations": {
    "vscode": {
      "extensions": ["VoidZero.vite-plus-extension-pack", "bradlc.vscode-tailwindcss"],
      "settings": {
        "npm.scriptRunner": "vp",
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "[javascript]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "oxc.fmt.configPath": "client/vite.config.ts",
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",
        "editor.codeActionsOnSave": {
          "source.fixAll.oxc": "explicit"
        },
        "files.associations": {
          "*.css": "tailwindcss"
        }
      }
    }
  }
}
